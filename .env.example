CLAUDE_API_KEY=sk-ant-api03-<...>
TELEGRAM_BOT_TOKEN=0000000000:<...>

DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6

TOKEN_BUDGET=32768
REPLY_BUDGET=4096

DATA_DIR=data
LOG_DIR=logs

IGNORE_PREFIX=//
SYSTEM_PREFIX=<System>

ADMIN_USER_IDS=

# Fernet master key for encrypting stored user credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset/malformed, credential storage is disabled (BYO-key commands refuse;
# the admin pool still works). Rotating this invalidates all stored keys.
CREDENTIAL_ENC_KEY=

# MCP server for persistent memory (optional).
# All five must be set to enable MCP tool access.
MCP_SERVER_URL=       # full URL of the MCP endpoint, e.g. https://example.com
MCP_TOKEN_URL=        # full URL of the OAuth token endpoint, e.g. https://example.com/token
MCP_SERVER_NAME=      # name passed to the Anthropic API, e.g. filesystem
MCP_CLIENT_ID=
MCP_CLIENT_SECRET=
